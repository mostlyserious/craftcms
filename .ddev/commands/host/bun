#!/usr/bin/env bash

## Description: Run bun in the DDEV web container with terminal support
## Usage: bun
## Example: "ddev bun"

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
# shellcheck source=.ddev/commands/host/.exec-web-command
. "$script_dir/.exec-web-command"

container_id="$(require_web_container)"

exec_in_web_container "$container_id" bun "$@"
